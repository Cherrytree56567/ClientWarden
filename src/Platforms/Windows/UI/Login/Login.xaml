<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsUI.Login"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WindowsUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid Margin="6">

        </Grid>
        <Grid Width="300">
            <StackPanel Orientation="Vertical"
            VerticalAlignment="Center"
            HorizontalAlignment="Stretch"
            Spacing="12">
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="8">
                    <Border Width="36"
                        Height="36"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                        <Image Source="/Assets/logo.png"
                           Stretch="UniformToFill"></Image>
                    </Border>
                    <TextBlock Text="Clientwarden"
                           FontFamily="Cascadia Mono"
                           FontWeight="SemiBold"
                           FontSize="24"
                           Foreground="White"
                           VerticalAlignment="Center"></TextBlock>
                </StackPanel>
                <TextBox PlaceholderText="Email"
                         x:Name="FieldEmail"></TextBox>
                <PasswordBox PlaceholderText="Password"
                             x:Name="FieldPassword"></PasswordBox>
                <TextBlock x:Name="FieldError"/>
                <Button Content="Login"
                    HorizontalAlignment="Stretch"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="LoginButton_Click"></Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
