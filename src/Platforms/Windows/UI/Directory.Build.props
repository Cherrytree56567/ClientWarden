
<Project>
  <PropertyGroup>
    <RuntimeIdentifiers>win10-x64</RuntimeIdentifiers>
    <NuGetTargetMoniker>native,Version=v0.0</NuGetTargetMoniker>
    <WindowsAppSDKAutoInitializeBootstrapper>false</WindowsAppSDKAutoInitializeBootstrapper>
    <IncludePath>$(GeneratedFilesDir);$(GeneratedFilesDir)winrt\;$(IncludePath)</IncludePath>
  </PropertyGroup>
</Project>