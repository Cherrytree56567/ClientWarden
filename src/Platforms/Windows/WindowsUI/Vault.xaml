<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsUI.Vault"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WindowsUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <NavigationView Grid.Column="0"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="True"
                        OpenPaneLength="220"
                        x:Name="NavView"
                        PaneTitle="Clientwarden">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="All Items" x:Name="AllItems">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/Logo.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Favorites" x:Name="Fav">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_star_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Trash" x:Name="Del">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_delete_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator/>

                <NavigationViewItemHeader Content="Types"/>
                <NavigationViewItem Content="Login" x:Name="Login">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_contact_card_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Card" x:Name="Card">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_credit_card_person_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Identity" x:Name="Identity">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_share_screen_person_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Secure Note" x:Name="SecNote">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_note_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="SSH Key" x:Name="SSH">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_key_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator/>

                <NavigationViewItemHeader Content="Folders"/>
                <NavigationViewItem Content="Test Folder">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_folder_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="New Folder" Icon="Add" x:Name="NewFold"/>
            </NavigationView.FooterMenuItems>
            <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                  Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Border BorderThickness="1, 0, 1, 0"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid VerticalAlignment="Top"
                                  Margin="12"
                                  Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <AutoSuggestBox Grid.Column="0"
                                                QueryIcon="Find"
                                                PlaceholderText="Search"/>
                
                                <Button Grid.Column="1"
                                        VerticalAlignment="Stretch"
                                        Margin="12, 0, 0, 0"
                                        Style="{ThemeResource AccentButtonStyle}">
                                    <FontIcon Glyph="&#xE710;" FontSize="16"/>
                                </Button>
                            </Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Grid.Row="1">
                                <StackPanel>
                                    <local:VaultItem Logo="ms-appx:///Assets/profile1.png"
                                                     Title="Test Website"
                                                     Detail="test@website.com"
                                                     Click="VaultItem_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <ScrollViewer Grid.Column="1"
                              Padding="64, 36, 64, 16"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Orientation="Vertical">
                        <CommandBar IsOpen="False"
                                    DefaultLabelPosition="Right"
                                    Margin="0, 0, -12, 0">
                            <AppBarButton Label="Edit">
                                <AppBarButton.Icon>
                                    <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_edit_24_regular.png"
                                                ShowAsMonochrome="True"/>
                                </AppBarButton.Icon>
                            </AppBarButton>
                            <AppBarButton Label="Duplicate">
                                <AppBarButton.Icon>
                                    <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_document_copy_24_regular.png"
                                                ShowAsMonochrome="True"/>
                                </AppBarButton.Icon>
                            </AppBarButton>
                            <AppBarButton Label="Delete">
                                <AppBarButton.Icon>
                                    <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_delete_24_regular.png"
                                                ShowAsMonochrome="True"/>
                                </AppBarButton.Icon>
                            </AppBarButton>
                        </CommandBar>
                        <Grid Margin="0, 16, 0, 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="4"
                                    Grid.Column="0">
                                <Image Source="ms-appx:///Assets/profile1.png"
                                       Width="42"/>
                            </Border>
                            <StackPanel Orientation="Vertical"
                                        Margin="12, 0, 0, 0"
                                        Grid.Column="1">
                                <TextBlock Text="Test Website"
                                           FontWeight="Bold"
                                           FontSize="24"/>
                                <TextBlock Text="Login"
                                           FontSize="10"
                                           VerticalAlignment="Bottom"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Grid HorizontalAlignment="Right"
                                  Grid.Column="2">
                                <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_star_24_regular.png"
                                            ShowAsMonochrome="True"
                                            Width="20"/>
                            </Grid>
                        </Grid>
                        <Border BorderThickness="0, 0, 0, 1"
                                Padding="0, 32, 0, 0"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <local:GenericField Title="Username"
                                            Value="test@website.com"/>
                        <local:PasswordField Title="Password"
                                             Value="TestPassword"/>
                        <local:TOTPField Title="TOTP"
                                         Value="453 673"
                                         Time="25"/>
                        <local:WebsiteField Title="Websites">
                            <local:WebsiteField.Value>
                                <TextBlock Text="a@a.com"/>
                                <TextBlock Text="a@a.com"/>
                            </local:WebsiteField.Value>
                        </local:WebsiteField>
                        
                        <Border BorderThickness="0, 0, 0, 1"
                                Padding="0, 8, 0, 0"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <UserControl Margin="0, 8, 0, 0">
                            <Border Padding="10, 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Notes" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Padding="0, 0, 0, 4"/>
                                        <TextBlock TextWrapping="WrapWholeWords" 
                                                   Text="Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s"
                                                   FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </UserControl>
                        <Border BorderThickness="0, 0, 0, 1"
                                Padding="0, 8, 0, 0"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <local:TextField Title="Text Field 1" Value="Some Text"/>
                        <local:HiddenField Title="Hidden Field 24" Value="Some Hidden Text"/>
                        <local:CheckboxField Title="Some Checkbox" Value="False"/>
                        <local:LinkedField Title="Linked Field 9" Value="Username"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
