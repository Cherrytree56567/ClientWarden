<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsUI.Vault"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WindowsUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <NavigationView Grid.Column="0"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="True"
                        OpenPaneLength="220"
                        Loaded="NavigationView_Loaded"
                        x:Name="NavView"
                        PaneTitle="Clientwarden">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="All Items" x:Name="AllItems">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/logo.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Favorites" x:Name="Fav">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_star_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Trash" x:Name="Del">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_delete_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator/>

                <NavigationViewItemHeader Content="Types"/>
                <NavigationViewItem Content="Login" x:Name="Login">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_contact_card_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Card" x:Name="Card">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_credit_card_person_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Identity" x:Name="Identity">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_share_screen_person_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Secure Note" x:Name="SecNote">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_note_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="SSH Key" x:Name="SSH">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_key_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator/>

                <NavigationViewItemHeader Content="Folders"/>
                <NavigationViewItem Content="Test Folder">
                    <NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_folder_24_regular.png"
                                    ShowAsMonochrome="True"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="New Folder" Icon="Add" x:Name="NewFold"/>
            </NavigationView.FooterMenuItems>
            <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                  Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Border BorderThickness="1, 0, 1, 0"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                        <StackPanel>
                            <Grid VerticalAlignment="Top"
                                  Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <AutoSuggestBox Grid.Column="0"
                                                QueryIcon="Find"
                                                PlaceholderText="Search"/>
                
                                <Button Grid.Column="1"
                                        VerticalAlignment="Stretch"
                                        Margin="12, 0, 0, 0"
                                        Style="{ThemeResource AccentButtonStyle}">
                                    <FontIcon Glyph="&#xE710;" FontSize="16"/>
                                </Button>
                            </Grid>
                            <Grid Padding="12, 0, 12, 12">
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        Padding="12, 12, 12, 12"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Left">
                                        <Border CornerRadius="4">
                                            <Image Source="/Assets/profile1.png"
                                                   Width="32"/>
                                        </Border>
                                        <Grid Margin="12, 0, 0, 0">
                                            <TextBlock Text="Test Website"
                                                       FontWeight="Bold"
                                                       FontSize="14"/>
                                            <TextBlock Text="email@website.com"
                                                       FontSize="10"
                                                       VerticalAlignment="Bottom"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </Grid>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <ScrollViewer Grid.Column="1"
                              Padding="64, 36, 64, 16"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Orientation="Vertical">
                        <CommandBar IsOpen="False"
                                    DefaultLabelPosition="Right"
                                    Margin="0, 0, -12, 0">
                            <AppBarButton Label="Edit">
                                <AppBarButton.Icon>
                                    <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_edit_24_regular.png"
                                                ShowAsMonochrome="True"/>
                                </AppBarButton.Icon>
                            </AppBarButton>
                            <AppBarButton Label="Duplicate">
                                <AppBarButton.Icon>
                                    <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_document_copy_24_regular.png"
                                                ShowAsMonochrome="True"/>
                                </AppBarButton.Icon>
                            </AppBarButton>
                            <AppBarButton Label="Delete">
                                <AppBarButton.Icon>
                                    <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_delete_24_regular.png"
                                                ShowAsMonochrome="True"/>
                                </AppBarButton.Icon>
                            </AppBarButton>
                        </CommandBar>
                        <Grid Margin="0, 16, 0, 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="4"
                                    Grid.Column="0">
                                <Image Source="/Assets/profile1.png"
                                       Width="42"/>
                            </Border>
                            <StackPanel Orientation="Vertical"
                                        Margin="12, 0, 0, 0"
                                        Grid.Column="1">
                                <TextBlock Text="Test Website"
                                           FontWeight="Bold"
                                           FontSize="24"/>
                                <TextBlock Text="Login"
                                           FontSize="10"
                                           VerticalAlignment="Bottom"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Grid HorizontalAlignment="Right"
                                  Grid.Column="2">
                                <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_star_24_regular.png"
                                            ShowAsMonochrome="True"
                                            Width="20"/>
                            </Grid>
                        </Grid>
                        <Border BorderThickness="0, 0, 0, 1"
                                Padding="0, 24, 0, 0"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <Button Margin="0, 16, 0, 0"
                                Padding="0"
                                Background="Transparent"
                                CornerRadius="6"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch">
                            <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10, 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Username" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="email@website.com"
                                                   FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                        <Button Margin="0, 8, 0, 0"
                                Padding="0"
                                Background="Transparent"
                                CornerRadius="6"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch">
                            <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10, 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Password" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="Password123"
                                                   FontSize="14"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Margin="-10"
                                            Padding="16">
                                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_eye_show_24_regular.png"
                                                    ShowAsMonochrome="True"
                                                    Width="20"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </Button>
                        <Button Margin="0, 8, 0, 0"
                                Padding="0"
                                Background="Transparent"
                                CornerRadius="6"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch">
                            <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10, 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="TOTP" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="132 432"
                                                   FontSize="14"/>
                                    </StackPanel>
                                    <Grid Grid.Column="1"
                                          Width="24"
                                          Height="24">
                                        <ProgressRing IsIndeterminate="False"
                                                      Minimum="0"
                                                      Maximum="30"
                                                      Value="12"
                                                      Width="24"
                                                      Height="24"/>
                                        <TextBlock Text="15"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="10"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Button>
                        <UserControl Margin="0, 8, 0, 0">
                            <Border Padding="10, 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Website" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Padding="0, 0, 0, 4"/>
                                        <TextBlock Text="website.com"
                                                   FontSize="14"/>
                                        <TextBlock Text="example.com"
                                                   FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </UserControl>
                        <Border BorderThickness="0, 0, 0, 1"
                                Padding="0, 8, 0, 0"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <UserControl Margin="0, 8, 0, 0">
                            <Border Padding="10, 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Notes" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Padding="0, 0, 0, 4"/>
                                        <TextBlock TextWrapping="WrapWholeWords" 
                                                   Text="Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s"
                                                   FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </UserControl>
                        <Border BorderThickness="0, 0, 0, 1"
                                Padding="0, 8, 0, 0"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <UserControl Margin="0, 8, 0, 0">
                            <Border Padding="10, 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Text Field 1" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Padding="0, 0, 0, 4"/>
                                        <TextBlock TextWrapping="WrapWholeWords" 
                                                   Text="Some Text ig"
                                                   FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </UserControl>
                        <UserControl Margin="0, 8, 0, 0">
                            <Border Padding="10, 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Hidden Field 1" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Padding="0, 0, 0, 4"/>
                                        <TextBlock TextWrapping="WrapWholeWords" 
                                                   Text="Some Text ig"
                                                   FontSize="14"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Margin="-10"
                                            Padding="16">
                                        <BitmapIcon UriSource="ms-appx:///Assets/ic_fluent_eye_show_24_regular.png"
                                                    ShowAsMonochrome="True"
                                                    Width="20"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </UserControl>
                        <UserControl Margin="0, 0, 0, 0">
                            <Border Padding="10, 0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" 
                                                Spacing="2"
                                                Orientation="Horizontal">
                                        <CheckBox Content="Checkbox 1"
                                                  VerticalAlignment="Center"
                                                  VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </UserControl>
                        <UserControl Margin="0, 8, 0, 0">
                            <Border Padding="10, 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Linked Field 1" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Padding="0, 0, 0, 4"/>
                                        <TextBlock TextWrapping="WrapWholeWords" 
                                                   Text="Username"
                                                   FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </UserControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
